# ── CosyVoice model ──────────────────────────────────────────────────────────
# Path to the downloaded model directory (relative or absolute)
MODEL_DIR=./models/Fun-CosyVoice3-0.5B

# ── HuggingFace upload ───────────────────────────────────────────────────────
# Your HF write token — get it from https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxx

# The HF dataset/model repo where generated audio will be uploaded
# e.g.  your-username/tts-outputs
HF_REPO_ID=your-username/tts-outputs

# Repo type: "dataset" or "model" (dataset recommended for audio files)
HF_REPO_TYPE=dataset

# ── Model acceleration (Linux + NVIDIA GPU only) ─────────────────────────────
# Set to "true" to enable. All default to false for portability.
LOAD_FP16=false      # FP16 inference (requires CUDA)
LOAD_VLLM=false      # vLLM internal LLM accelerator (requires vLLM 0.11+)
LOAD_TRT=false       # TensorRT (requires tensorrt-cu12 ≥ 10.x, Linux only)
LOAD_JIT=false       # TorchScript JIT (works on any platform)

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Gradio UI ─────────────────────────────────────────────────────────────────
GRADIO_PORT=7860
# URL the Gradio container uses to reach the API (Docker internal network)
# API_URL=http://api:8000

# ── Storage ──────────────────────────────────────────────────────────────────
# Directory where uploaded voice seeds are stored
VOICES_DIR=./voices

# Directory for temporarily storing generated audio before upload
OUTPUT_DIR=./outputs
